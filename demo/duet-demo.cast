[0.402, "o", "\u001b[36m--- a/app/auth.py\u001b[0m\r\n\u001b[36m+++ b/app/auth.py\u001b[0m\r\n\u001b[2m@@ -1,14 +1,20 @@\u001b[0m\r\n\u001b[32m+import time\u001b[0m\r\n\u001b[32m+\u001b[0m\r\n\u001b[32m+WINDOW = 60\u001b[0m\r\n\u001b[32m+MAX_ATTEMPTS = 5\u001b[0m\r\n login_attempts = {}  \u001b[2m# ip -> list[timestamp]\u001b[0m\r\n\r\n @app.post(\"/login\")\r\n def login():\r\n     ip = request.remote_addr\r\n\u001b[32m+    now = time.time()\u001b[0m\r\n\u001b[32m+    recent = [t for t in login_attempts.get(ip, []) if now - t < WINDOW]\u001b[0m\r\n\u001b[31m-    if login_attempts.get(ip, 0) >= 5:\u001b[0m\r\n\u001b[32m+    if len(recent) >= MAX_ATTEMPTS:\u001b[0m\r\n         abort(429, \"Too many attempts\")\r\n     user = authenticate(request.form[\"email\"], request.form[\"password\"])\r\n     if user is None:\r\n\u001b[31m-        login_attempts[ip] = login_attempts.get(ip, 0) + 1\u001b[0m\r\n\u001b[32m+        recent.append(now)\u001b[0m\r\n         abort(401)\r\n\u001b[32m+    login_attempts[ip] = recent\u001b[0m\r\n     return start_session(user)\r\n"]
[1.602, "o", "\r\n\u001b[1m\u001b[32mTwo models, two vendors. One wrote it, the other refused to let a real bug ship. You commit.\u001b[0m\r\n\r\n"]
